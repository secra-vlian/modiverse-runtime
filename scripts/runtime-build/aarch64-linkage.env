# Per-component linkage strategy for aarch64 hybrid Runtime builds.
# musl-official-apk   — Alpine Linux apk (official musl packages)
# musl-official-bin   — upstream release explicitly built for musl
# musl-static-bin     — official static Go binary (runs on musl without shipping libc)
# glibc-source        — no usable official musl; build from upstream source on manylinux2014

MDV_LINKAGE_common_libs=glibc-source
MDV_LINKAGE_nginx=musl-official-apk
MDV_LINKAGE_postgresql=musl-official-apk
MDV_LINKAGE_redis=musl-official-apk
MDV_LINKAGE_zeromq=musl-official-apk
MDV_LINKAGE_ffmpeg=musl-official-apk
MDV_LINKAGE_tusd=musl-static-bin
MDV_LINKAGE_opentelemetry=musl-static-bin
MDV_LINKAGE_openobserve=musl-official-bin
MDV_LINKAGE_poppler=glibc-source
MDV_LINKAGE_libreoffice=glibc-source

# Alpine branches/repos for apk pulls (edge used when v3.22 lacks the pinned version).
MDV_ALPINE_BRANCH_stable=v3.22
MDV_ALPINE_NGINX_PKG=nginx
MDV_ALPINE_NGINX_VER=1.28.3-r6
MDV_ALPINE_POSTGRESQL_PKG=postgresql17
MDV_ALPINE_POSTGRESQL_VER=17.10-r0
MDV_ALPINE_REDIS_BRANCH=edge
MDV_ALPINE_REDIS_PKG=redis
MDV_ALPINE_REDIS_VER=8.8.0-r0
MDV_ALPINE_ZEROMQ_PKG=zeromq
MDV_ALPINE_ZEROMQ_VER=4.3.5-r2
MDV_ALPINE_FFMPEG_BRANCH=edge
MDV_ALPINE_FFMPEG_PKG=ffmpeg
MDV_ALPINE_FFMPEG_VER=8.1.2-r0
