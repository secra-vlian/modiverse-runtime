.DS_Store
._*

# Runtime archives are published as GitHub/Gitee Release assets, not committed to Git.
runtime/**/*.tar.gz

# Build output remains local and can be regenerated.
runtime/**/build.log
runtime/**/build-inner.log
runtime/**/build-inner.exit
runtime/**/mark.txt

# Host-side source cache for large offline downloads (LibreOffice, toolsets, etc.).
.cache/

# Offline source and binary staging generated by download scripts.
modiverse-repository/
dist/
.tmp/

# Assembled offline media / deferred L1-L2 quarantine (regenerable).
runtime/offline-L0-aarch64/mdv-installer
runtime/deferred-aarch64-l1-l2/**/*.tar.gz
